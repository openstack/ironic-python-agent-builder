#!/bin/bash
set -eux

# Compile nccl-tests against the CUDA toolkit and NCCL installed in the image.
# Only the resulting binaries are kept; sources and build artifacts are removed.
NCCL_TESTS_REF="${DIB_NCCL_TESTS_REF:-master}"

git clone --depth=1 --branch "${NCCL_TESTS_REF}" \
    https://github.com/NVIDIA/nccl-tests /tmp/nccl-tests

make -C /tmp/nccl-tests \
    CUDA_HOME=/usr/local/cuda \
    MPI=0 \
    -j"$(nproc)"

install -d /usr/local/bin/nccl-tests
install -m 755 /tmp/nccl-tests/build/*_perf /usr/local/bin/nccl-tests/
rm -rf /tmp/nccl-tests
